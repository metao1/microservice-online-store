@@ -0,0 +1,128 @@
+name: Performance SLO Gate
+
+# Enforces Phase 6 of docs/ROADMAP_IMPLEMENTATION_PLAN.md:
+# "Define and enforce performance SLO gates in CI for key endpoints."
+#
+# The performance-loadtest runner already exits non-zero when a scenario
+# breaches its configured thresholds (error rate / p95 / p99 / throughput)
+# OR when it regresses beyond the tolerances in `comparison.compareTo`.
+# This workflow wires that gate to CI.
+#
+# Booting Kafka + 3 Postgres + 3 services is too heavy for PR CI (~8 min cold
+# start), so we run it nightly + on manual dispatch. Baseline reports live in
+# `performance-loadtest/reports/` and are committed by maintainers; a
+# regression fails the workflow and uploads the diff as an artifact.
+
+on:
+  workflow_dispatch:
+    inputs:
+      scenario:
+        description: 'Scenario name to run (leave blank for all)'
+        required: false
+        type: string
+  schedule:
+    # Every night at 02:00 UTC. Keeps a continuous signal on trunk without
+    # slowing down PR feedback.
+    - cron: '0 2 * * *'
+
+concurrency:
+  # Only one perf run at a time — they contend on CPU/NIC and would invalidate
+  # each other's latency numbers.
+  group: performance-slo-${{ github.ref }}
+  cancel-in-progress: false
+
+jobs:
+  run-load-tests:
+    runs-on: ubuntu-22.04
+    timeout-minutes: 45
+    strategy:
+      fail-fast: false
+      matrix:
+        scenario:
+          - payment-status-page
+          - inventory-category-page-ramp
+          - bookstore-e2e-order-payment-inventory
+    steps:
+      - uses: actions/checkout@v4.2.2
+
+      - name: Set up JDK 21
+        uses: actions/setup-java@v4.7.1
+        with:
+          java-version: '21'
+          distribution: 'temurin'
+
+      - name: Skip non-matching scenarios on manual dispatch
+        if: ${{ inputs.scenario != '' && inputs.scenario != matrix.scenario }}
+        run: |
+          echo "Skipping ${{ matrix.scenario }} (manual dispatch requested ${{ inputs.scenario }})"
+          echo "SKIP_RUN=1" >> "$GITHUB_ENV"
+
+      - name: Build runtime images
+        if: ${{ env.SKIP_RUN != '1' }}
+        run: |
+          ./gradlew publishToMavenLocal --no-configuration-cache
+          ./gradlew :inventory-microservice:bootBuildImage \
+                    :payment-microservice:bootBuildImage \
+                    :order-microservice:bootBuildImage \
+                    --no-configuration-cache
+
+      - name: Boot stack
+        if: ${{ env.SKIP_RUN != '1' }}
+        run: docker compose up -d
+
+      - name: Wait for services to be healthy
+        if: ${{ env.SKIP_RUN != '1' }}
+        run: |
+          # Poll the service ports rather than arbitrary sleep — Spring Boot
+          # startup varies with CI runner load.
+          for endpoint in \
+              "http://localhost:8083/actuator/health" \
+              "http://localhost:8084/actuator/health" \
+              "http://localhost:8086/actuator/health"; do
+            for attempt in $(seq 1 60); do
+              if curl -sf --max-time 2 "$endpoint" >/dev/null; then
+                echo "READY: $endpoint"
+                break
+              fi
+              if [ "$attempt" -eq 60 ]; then
+                echo "Service never became healthy: $endpoint"
+                docker compose logs --tail=200
+                exit 1
+              fi
+              sleep 5
+            done
+          done
+
+      - name: Run load test with SLO gate
+        if: ${{ env.SKIP_RUN != '1' }}
+        run: |
+          ./gradlew :performance-loadtest:run --no-configuration-cache --args="\
+            --scenario-file performance-loadtest/scenarios/bookstore-scenarios.json \
+            --scenario ${{ matrix.scenario }} \
+            --report-dir performance-loadtest/reports/ci/${{ matrix.scenario }}"
+
+      - name: Upload report artifacts
+        if: ${{ always() && env.SKIP_RUN != '1' }}
+        uses: actions/upload-artifact@v4
+        with:
+          name: perf-report-${{ matrix.scenario }}-${{ github.run_number }}
+          path: performance-loadtest/reports/ci/${{ matrix.scenario }}/
+          if-no-files-found: warn
+          retention-days: 30
+
+      - name: Dump service logs on failure
+        if: ${{ failure() && env.SKIP_RUN != '1' }}
+        run: docker compose logs --no-color --tail=500 > services.log || true
+
+      - name: Upload service logs on failure
+        if: ${{ failure() && env.SKIP_RUN != '1' }}
+        uses: actions/upload-artifact@v4
+        with:
+          name: service-logs-${{ matrix.scenario }}-${{ github.run_number }}
+          path: services.log
+          if-no-files-found: ignore
+          retention-days: 14
+
+      - name: Tear down stack
+        if: ${{ always() && env.SKIP_RUN != '1' }}
+        run: docker compose down --volumes --remove-orphans
